{
  "name": "@superkut/subagents",
  "version": "0.2.0",
  "description": "CLI for installing cross-agent subagent definitions from git repos, URLs, or local paths",
  "type": "module",
  "bin": {
    "subagents": "./bin/cli.mjs",
    "add-subagent": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "ThirdPartyNoticeText.txt"
  ],
  "scripts": {
    "build": "node scripts/generate-licenses.ts && obuild",
    "generate-licenses": "node scripts/generate-licenses.ts",
    "dev": "node src/cli.ts",
    "exec:test": "node scripts/execute-tests.ts",
    "prepublishOnly": "npm run build",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "prepare": "husky",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "commit": "cz",
    "release": "cz bump",
    "publish:snapshot": "npm version prerelease --preid=snapshot --no-git-tag-version && npm publish --tag snapshot"
  },
  "lint-staged": {
    "src/**/*.ts": "prettier --write",
    "scripts/**/*.ts": "prettier --write",
    "tests/**/*.ts": "prettier --write"
  },
  "keywords": [
    "cli",
    "agent-subagents",
    "subagents",
    "ai-agents",
    "amp",
    "claude-code",
    "codex",
    "cursor",
    "factory",
    "opencode"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebsmith/subagents.git"
  },
  "homepage": "https://github.com/kalebsmith/subagents#readme",
  "bugs": {
    "url": "https://github.com/kalebsmith/subagents/issues"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "obuild": "^0.4.22",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "simple-git": "^3.27.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "xdg-basedir": "^5.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
